modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
NODE_ENV = "production"
VAPID_SUBJECT = "mailto:support@entanglewealth.com"

[userenv.production]
VITE_CLERK_PROXY_URL = "https://entanglewealth.com/api/__clerk"

[objectStorage]
defaultBucketID = "replit-objstore-4394a36d-c5bb-4bd2-8ce4-f93a77009407"
