{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "stress": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/run-all.mjs",
    "stress:01": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/01-endpoint-saturation.mjs",
    "stress:02": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/02-resilience-mechanisms.mjs",
    "stress:03": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/03-db-pool-saturation.mjs",
    "stress:04": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/04-lru-map-bounds.mjs",
    "stress:05": "STRESS_BASE_URL=${STRESS_BASE_URL:-http://localhost:8080} node stress/05-request-timeout.mjs"
  },
  "dependencies": {
    "@clerk/express": "^2.0.8",
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.6.1",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-connect": "^0.57.0",
    "@opentelemetry/instrumentation-dns": "^0.57.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-fs": "^0.33.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/instrumentation-net": "^0.58.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/instrumentation-undici": "^0.24.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.48.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/occupations": "workspace:*",
    "@workspace/xp": "workspace:*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
