{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm')){console.error('Use pnpm instead');process.exit(1)}\" && node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.unlinkSync(f)}catch{}})\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "@tailwindcss/oxide-win32-x64-msvc": "4.2.2",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  },
  "dependencies": {
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "stripe": "20.0.0",
    "stripe-replit-sync": "1.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@sentry/cli",
      "esbuild"
    ]
  }
}
